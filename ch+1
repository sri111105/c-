using System;

class Program
{
    static void Main()
    {
        Console.Write("Enter String: ");
        string str = Console.ReadLine();

        for (int i = 0; i < str.Length; i++)
        {
            char ch = (char)(str[i] + 1);

            if (ch >= 'A' && ch <= 'Z')
                ch = (char)(ch + 32);
            else if (ch >= 'a' && ch <= 'z')
                ch = (char)(ch - 32);

            Console.Write(ch);
        }
    }
}
